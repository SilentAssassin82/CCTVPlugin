<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <runtime>
    <!-- Server GC uses a dedicated high-priority thread per CPU core for collections,
         running concurrently with application threads.  This dramatically reduces
         pause times caused by the frequent LOH allocations from frame rendering
         (pixel buffers, StringBuilders, GZip streams).
         Workstation GC (the default) performs blocking Gen2 collections on the
         allocating thread, which causes the frame-send hangs on the 7700K. -->
    <gcServer enabled="true" />
    <!-- Allow concurrent (background) Gen2 collections so the main loop is not
         blocked during full compacting sweeps of the LOH. -->
    <gcConcurrent enabled="true" />
  </runtime>
</configuration>
